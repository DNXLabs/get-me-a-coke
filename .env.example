# AWS Configuration
AWS_PROFILE=nonprod-dnxai
AWS_REGION=ap-southeast-2

# Vending Machine
VENDING_MACHINE_URL=http://localhost:8000

# Wallet Service
WALLET_SERVICE_URL=http://localhost:8001
WALLET_API_KEY=dev-wallet-key-change-me

# Agent — Bedrock Model
BEDROCK_MODEL_ID=nvidia.nemotron-nano-3-30b

# Agent — Bedrock Prompt Management
BEDROCK_PROMPT_ID=Z0V9YJ7G7N
BEDROCK_PROMPT_VERSION=1

# Agent — AgentCore Payments
PAYMENT_MANAGER_ARN=arn:aws:bedrock-agentcore:ap-southeast-2:<AWS_ACCOUNT_ID>:payment-manager/REPLACE_ME
PAYMENT_INSTRUMENT_ID=REPLACE_ME
PAYMENT_SESSION_ID=REPLACE_ME
PAYMENT_USER_ID=thiago

# Observability — Grafana Cloud
GRAFANA_OTLP_ENDPOINT=https://YOUR-STACK.grafana.net/otlp
GRAFANA_INSTANCE_ID=YOUR_INSTANCE_ID
GRAFANA_API_TOKEN=YOUR_API_TOKEN

# Observability — Sigil
# Sigil ingest endpoint URL
SIGIL_ENDPOINT=https://sigil-prod-REGION.grafana.net
SIGIL_PROTOCOL=http/protobuf
SIGIL_AUTH_MODE=token
SIGIL_AUTH_TENANT_ID=REPLACE_ME
SIGIL_AUTH_TOKEN=glc_REPLACE_ME
